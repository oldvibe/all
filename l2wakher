#[derive(Debug, Clone, PartialEq)]
pub struct Matrix(
   pub ( i32,  i32),
   pub ( i32,  i32)
);

pub fn multiply(m: Matrix, multiplier: i32) -> Matrix {
    return Matrix((m.0.0 * multiplier, m.0.1 * multiplier), (m.1.0 * multiplier, m.1.1 * multiplier));
}